{
  "name": "@rxtech-lab/admin-generator-next",
  "version": "0.1.0",
  "description": "Schema-driven admin UI for Next.js. Renders admin pages from a backend JSON schema (pairs with the admin-generator Go package).",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rxtech-lab/admin-generator.git",
    "directory": "packages/admin-next"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/theme.css dist/theme.css",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@rjsf/core": "6.1.1",
    "@rjsf/utils": "6.1.1",
    "@rjsf/validator-ajv8": "6.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "lucide-react": "^0.475.0",
    "swr": "^2.3.2",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
